# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=False
# LOG_LEVEL=INFO
# LOG_FILE=./data/app.log

# 企业微信配置
WECOM_CORP_ID=
WECOM_APP_ID=
WECOM_APP_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# Dify 配置
DIFY_API_KEY=
DIFY_BASE_URL=https://api.dify.ai/v1

# 数据库类型: sqlite 或 mysql (兼容 MariaDB)
DB_TYPE=sqlite

# SQLite 配置 (DB_TYPE=sqlite 时生效)
SQLITE_DB_PATH=./data/dify_wecom_bridge.db

# MySQL/MariaDB 配置 (DB_TYPE=mysql 时生效)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=dify_wecom
MYSQL_PASSWORD=
MYSQL_DATABASE=dify_wecom_bridge

# Redis 配置 (本地部署用 127.0.0.1, Docker 部署用 redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
